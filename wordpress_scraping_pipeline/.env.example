# =============================================================================
# WordPress Scraping Pipeline - Environment Configuration
# Copy this file to .env and update with your values
# =============================================================================

# =============================================================================
# GOOGLE CLOUD / BIGQUERY CONFIGURATION
# =============================================================================

# Google Cloud Project ID (Required)
GCP_PROJECT_ID=your-project-id

# BigQuery Dataset Name
BIGQUERY_DATASET=strapi_content_data

# BigQuery Table (existing table - do NOT create)
BIGQUERY_TABLE=unified_all_cms_content

# Path to Google Cloud Service Account JSON Key File
GOOGLE_APPLICATION_CREDENTIALS=../data/service-account.json


# =============================================================================
# SCRAPING CONFIGURATION
# =============================================================================

# User Agent for HTTP requests
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Delay between requests in seconds (be polite!)
REQUEST_DELAY=1.5

# Maximum retry attempts for failed requests
MAX_RETRIES=3


# =============================================================================
# WIKIMEDIA CONFIGURATION
# =============================================================================

# Wikimedia API (optional) - leave empty for anonymous access
WIKIMEDIA_API_KEY=

# Number of Wikimedia images to fetch per article
WIKIMEDIA_MAX_IMAGES=2


# =============================================================================
# FLASK WEB UI CONFIGURATION
# =============================================================================

# Flask host (0.0.0.0 allows external access)
FLASK_HOST=0.0.0.0

# Flask port
FLASK_PORT=5000

# Debug mode (set to False in production)
FLASK_DEBUG=True


# =============================================================================
# DATABASE PATHS
# =============================================================================

# SQLite database for URL tracking
SCRAPED_URLS_DB=../data/scraped_urls.db

# SQLite database for checkpoints
CHECKPOINTS_DB=../data/checkpoints.db


# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=../logs/wordpress_pipeline.log


# =============================================================================
# BATCH PROCESSING
# =============================================================================

# Number of records per BigQuery insert batch
INSERT_BATCH_SIZE=20

# Number of URLs to process before saving checkpoint
CHECKPOINT_INTERVAL=50

# =============================================================================
# SUPABASE (State Tracking)
# =============================================================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
