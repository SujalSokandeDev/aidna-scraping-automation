# =============================================================================
# CMS INCREMENTAL PIPELINE CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# BUSINESSABC CMS
# -----------------------------------------------------------------------------
BUSINESSABC_STRAPI_GRAPHQL_URL=https://cms.businessabc.net/graphql
BUSINESSABC_STRAPI_BEARER_TOKEN=your_businessabc_token_here

# -----------------------------------------------------------------------------
# SPORTSABC CMS
# -----------------------------------------------------------------------------
SPORTSABC_STRAPI_GRAPHQL_URL=https://cms.sportsabc.org/graphql
SPORTSABC_STRAPI_BEARER_TOKEN=your_sportsabc_token_here

# -----------------------------------------------------------------------------
# GOOGLE CLOUD / BIGQUERY
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=strapi_content_data
BIGQUERY_TABLE=unified_cms_content_combined
# Path to service account JSON (relative to data/ folder)
GOOGLE_CREDENTIALS_PATH=./data/service-account.json

# -----------------------------------------------------------------------------
# SUPABASE (State Tracking)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# -----------------------------------------------------------------------------
# PIPELINE SETTINGS
# -----------------------------------------------------------------------------
PAGE_SIZE=25
REQUEST_DELAY=1.0
MAX_RETRIES=3
INSERT_BATCH_SIZE=20

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/cms_pipeline.log

# -----------------------------------------------------------------------------
# FLASK WEB DASHBOARD
# -----------------------------------------------------------------------------
FLASK_PORT=5001
FLASK_DEBUG=false
